{
  "name": "html-previewer",
  "displayName": "HTML Previewer 2.0",
  "description": "Modern, dependency-free HTML preview for VS Code. One click, live reload, zero config — a fresh take on the abandoned html-preview classic.",
  "version": "2.0.1",
  "publisher": "deyvisonsouto",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/deyvisonsouto/html-preview-extension.git"
  },
  "bugs": {
    "url": "https://github.com/deyvisonsouto/html-preview-extension/issues"
  },
  "homepage": "https://github.com/deyvisonsouto/html-preview-extension#readme",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "html",
    "preview",
    "live preview",
    "browser",
    "webview",
    "render",
    "static"
  ],
  "galleryBanner": {
    "color": "#1E1E1E",
    "theme": "dark"
  },
  "activationEvents": [
    "onLanguage:html"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "htmlPreviewer.open",
        "title": "Preview HTML",
        "icon": "$(open-preview)",
        "category": "HTML Previewer"
      },
      {
        "command": "htmlPreviewer.refresh",
        "title": "Refresh Preview",
        "icon": "$(refresh)",
        "category": "HTML Previewer"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceLangId == html",
          "command": "htmlPreviewer.open",
          "group": "navigation"
        },
        {
          "when": "activeWebviewPanelId == htmlPreviewer",
          "command": "htmlPreviewer.refresh",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "when": "resourceLangId == html",
          "command": "htmlPreviewer.open",
          "group": "navigation@10"
        }
      ],
      "commandPalette": [
        {
          "command": "htmlPreviewer.open",
          "when": "resourceLangId == html"
        },
        {
          "command": "htmlPreviewer.refresh",
          "when": "activeWebviewPanelId == htmlPreviewer || resourceLangId == html"
        }
      ]
    },
    "keybindings": [
      {
        "command": "htmlPreviewer.open",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "editorLangId == html"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.x",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.3.0"
  }
}
